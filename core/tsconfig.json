{
  "compilerOptions": {
    "outDir": "dist",

    "rootDir": "src",

    "baseUrl": "./src",

    "target": "ES2022",

    "module": "esnext",

    "moduleResolution": "bundler",

    "strict": true,

    "experimentalDecorators": true,

    "emitDecoratorMetadata": true,

    "useDefineForClassFields": false,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "sourceMap": true,

    "incremental": true,

    "composite": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}
